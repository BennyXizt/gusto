<%
	blockClass = 'slider'

	var sliderContents = [
		{
			header: {
				tag: 'h1',
				label: '“The Best Pasta Outside of Italy”'
			},
			text: {
				label: [
					'“I’m Italian, and let me tell you, this pasta tastes like home. The sauces are rich, the pasta is cooked to perfection, and the ambiance is fantastic. Highly recommend this place!',
				]
			}
		},
		{
			header: {
				tag: 'h1',
				label: '“Authentic slice of Italy in Prague!”'
			},
			text: {
				label: [
					`“The pasta is freshly made, the sauces are bursting with flavor, and the desserts are divine. The owners' passion for Italian cuisine truly shines through. Highly recommend for anyone craving real Italian food!"`
				]
			}
		},
		{
			header: {
				tag: 'h1',
				label: `From Tuscany to the Heart of Prague`
			},
			text: {
				label: [
					`Moving from Tuscany to the heart of Prague wasn’t just about opening a restaurant—it was about creating a place where Italians and locals alike could gather around the table and experience Italy’s culinary magic.`
				]
			}
		},
		{
			header: {
				tag: 'h1',
				label: `“A must-visit for Italian food lovers in Prague.”`
			},
			text: {
				label: [
