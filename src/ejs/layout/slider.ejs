							]
						},
						{  
							type: 'image/webp', 
							srcset: [
								`media/image/slider/${e}-sm.webp 480w`,
								`media/image/slider/${e}-md.webp 800w`,
								`media/image/slider/${e}-lg.webp 1200w`,
								`media/image/slider/${e}-xl.webp 1600w`,
								`media/image/slider/${e}-2xl.webp 2400w`
