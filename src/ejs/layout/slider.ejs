				]
			}
		},
		{
			header: {
				tag: 'h1',
				label: `“The most Authentic Italian experience”`
			},
			text: {
				label: [
					`"Absolutely phenomenal! The carbonara was cooked to perfection, and the wine pairing was spot on. It’s clear the owners pour their hearts into every dish. A delightful spot for a romantic evening or a casual lunch."`
				]
			}
		},
	]
	var sliderElements = ['sld1', 'sld2', 'sld3', 'sld4', 'sld5'].map((e, i) =>
		{
			return {
				content: sliderContents[i],
				image_component: {
					this: {
						class: `${blockClass}__background`,
						dataAttribute: `draggable=false`
					},
					img: {
						src: `media/image/slider/${e}-lg.jpg`,
						alt: e,
						width: 1484,
						height: 1056,
						loading: 'lazy',
						srcset: [
							`media/image/slider/${e}-sm.jpg 480w`,
							`media/image/slider/${e}-md.jpg 800w`,
							`media/image/slider/${e}-lg.jpg 1200w`,
							`media/image/slider/${e}-xl.jpg 1600w`,
							`media/image/slider/${e}-2xl.jpg 2400w`
						]
					},
					images: [
						{  
							type: 'image/avif', 
							srcset: [
								`media/image/slider/${e}-sm.avif 480w`,
								`media/image/slider/${e}-md.avif 800w`,
								`media/image/slider/${e}-lg.avif 1200w`,
								`media/image/slider/${e}-xl.avif 1600w`,
