					]
				},
				testimonial: {
					users: Array.from({ length: 3 }, (_, i) => {
						return {
							img: {
								src: `media/image/users/user-${i + 1}.jpg`,
								alt: `user-${i + 1}`
							}
						}
					}),
					rating: '3,8',
					reviews: {
						stars: 5,
						total: '1,280'
					}
				}
			}
		}
	)
	
%>

<section class='layout__<%=blockClass%> <%=blockClass%>'>
	<div class='<%=blockClass%>__container container'>
		<%- include('src/ejs/components/slider.ejs', {
			slider_component: {
				list: sliderElements
			}
		}) %>
	</div>
</section>